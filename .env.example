# Thor optional environment overrides
# Copy to .env only for your local environment. Do not commit real secrets, cookies, or tokens.

THOR_OUTPUT_DIR=results
THOR_LOG_DIR=logs
THOR_THREADS=50
THOR_HTTPX_THREADS=100
THOR_PARAMSPIDER_THREADS=20

# Dalfox safety/performance
THOR_DALFOX_WORKERS=25
THOR_DALFOX_TIMEOUT=8
THOR_DALFOX_RETRIES=1
THOR_DALFOX_BATCH_SIZE=250
THOR_DALFOX_PRECHECK_LIVE=true
THOR_DALFOX_REQUIRE_LIVE_HOSTS=true
THOR_DALFOX_SCOPE_ONLY=true
THOR_DALFOX_USE_OUTPUT_FLAG=false

# Optional authorized request customization. Leave blank unless explicitly allowed by scope.
THOR_PROXY=
THOR_COOKIES=
THOR_HEADERS=
THOR_USER_AGENT=Thor/1.0.0

# Set true only for authorized internal lab targets.
THOR_ALLOW_PRIVATE_TARGETS=false
